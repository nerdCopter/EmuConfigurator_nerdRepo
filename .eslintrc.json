{
  "env": {
    "browser": true,
    "es2021": true,
    "node": true
  },
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "globals": {
    "$": "readonly",
    "jQuery": "readonly",
    "i18next": "readonly",
    "i18n": "readonly",
    "chrome": "readonly",
    "d3": "readonly",
    "semver": "readonly",
    "bit_check": "readonly",
    "bit_set": "readonly",
    "bit_clear": "readonly",
    "Plotly": "readonly",
    "THREE": "readonly",
    "CONFIGURATOR": "readonly",
    "GUI": "readonly",
    "MSP": "readonly",
    "MSPCodes": "readonly",
    "TABS": "readonly",
    "ConfigStorage": "readonly",
    "FirmwareCache": "readonly",
    "configuration_backup": "readonly",
    "configuration_restore": "readonly",
    "initializeSerialBackend": "readonly",
    "CliAutoComplete": "readonly",
    "DarkTheme": "readonly",
    "FEATURE_CONFIG": "readonly",
    "ReleaseChecker": "readonly",
    "CONFIG": "readonly",
    "have_sensor": "readonly"
  },
  "rules": {
    "no-debugger": "warn",
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_" }],
    "complexity": "warn"
  },
  "ignorePatterns": [
    "dist/",
    "out/",
    "node_modules/",
    "libraries/",
    "presets/"
  ],
  "overrides": [
    {
      "files": [
        "test/**/*.js",
        "test/**/*.ts"
      ],
      "env": {
        "mocha": true
      },
      "rules": {
        "no-unused-expressions": "off"
      }
    },
    {
      "files": [
        "src/js/ConfigStorage.js",
        "src/js/FirmwareCache.js",
        "src/js/backup_restore.js"
      ],
      "parserOptions": {
        "sourceType": "script"
      },
      "rules": {
        "no-unused-vars": ["warn", { "argsIgnorePattern": "^_", "varsIgnorePattern": "^(ConfigStorage|FirmwareCache|configuration_backup|configuration_restore)$" }]
      }
    }
  ]
}
